# 广大大登录凭证（复制为 .env 并填入真实值）
GUANGDADA_EMAIL=your_email@example.com
GUANGDADA_PASSWORD=your_password

# 广大大登录页 Page.goto 超时（毫秒，默认 90000）。仍超时可加大或设 GUANGDADA_LOGIN_GOTO_WAIT_UNTIL=load
# GUANGDADA_LOGIN_GOTO_TIMEOUT_MS=120000
# GUANGDADA_LOGIN_GOTO_WAIT_UNTIL=load

# ---------- 本地代理（Clash 等）+ 广大大 Playwright 爬虫（run_search_workflow / video enhancer 抓取）----------
# Chromium 不读 HTTP_PROXY，脚本会读下面变量并传给 Playwright；与 Clash「端口设置」一致即可。
# PLAYWRIGHT_PROXY_SERVER=http://127.0.0.1:7890
# 或沿用通用变量（任选其一）：
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# macOS：若端口未监听，可让脚本执行 `open -a "应用名"` 启动客户端（应用名须与「应用程序」里一致）
# PROXY_AUTO_LAUNCH_APP=1
# PROXY_APP_NAME=Clash Verge
# PROXY_CHECK_HOST=127.0.0.1
# PROXY_CHECK_PORT=7890
# PROXY_WAIT_SECONDS=45
# 代理未就绪时直接退出（可选）
# PROXY_STRICT=1

# Video Enhancer：灵感分析提示词内合并「花卉背景 / 黑白大片」套路（同一次 JSON 输出；命中则打标「我方已经投过」且不同步主表、不参与聚类）
# VIDEO_ANALYSIS_STYLE_FILTER_DISABLED=1

# Video Enhancer：多模态封面日内聚类去重（同产品内封面风格聚类，每簇保留展示估值最高一条；会增加 LLM 调用）
# 默认开启；需关闭时取消下行注释或设为 0
# COVER_STYLE_INTRADAY_ENABLED=0
# 封面流程开头是否与 creative_library 做跨日指纹去重（ad_key/URL/ahash，与灵感分析 Step B 一致；默认开启）
# COVER_STYLE_CROSS_DAY_FINGERPRINT_ENABLED=0
# 封面聚类时是否载入「昨日」同 appid 的 insight_cover_style 与今日一起比较（默认开启；关闭则仅日内+指纹去重）
# COVER_STYLE_CROSS_DAY_ENABLED=0
# 同一 appid 内多条封面多模态并发数（默认 3；设为 1 串行）
# COVER_STYLE_WORKERS=3

# 灵感分析（analyze_video_from_raw_json.py）多条素材并行多模态（默认 3；设为 1 串行）
# VIDEO_ANALYSIS_WORKERS=3

# Video Enhancer 全流程（workflow_video_enhancer_full_pipeline.py）
# 飞书多维表同步、飞书卡片、企业微信推送里的「多维表格链接」均读取本变量（浏览器地址栏完整 URL，需含 table=）
VIDEO_ENHANCER_BITABLE_URL=https://scnmrtumk0zm.feishu.cn/base/W8QMbUR1vaiUGUskOF2cwnXenBe?table=tblRAiOqhIyJEAS9&view=vewd67ZK4J
# 聚类方向结果写入的多维表（每类一条，含标题/视频链接/接受情况）
# VIDEO_ENHANCER_CLUSTER_BITABLE_URL=https://scnmrtumk0zm.feishu.cn/base/W8QMbUR1vaiUGUskOF2cwnXenBe?table=tbllowSjhc5xkoVx&view=vewfU9buoq

# 日报生成（generate_ua_report.py）
# 优先 OpenRouter 中转（性价比高）
OPENROUTER_API_KEY=sk-or-xxx
# 每日工作流（daily_video_enhancer_workflow.sh）前后各 curl 一次 GET /api/v1/key，对比单次 run 用量（需 OPENROUTER_API_KEY）
# OPENROUTER_METER=1
# OPENROUTER_MODEL=google/gemini-2.5-flash  # 可选，默认即此
# 语义嵌入去重模型（默认 openai/text-embedding-3-small via OpenRouter）
# EMBEDDING_MODEL=openai/text-embedding-3-small
# 语义去重 cosine similarity 阈值（默认 0.92）
# SEMANTIC_DEDUP_THRESHOLD=0.92
# 或直连 OpenAI
# OPENAI_API_KEY=sk-xxx

# Video Enhancer → Google Sheet（Apps Script Web 应用 URL，见 sync_video_enhancer_date_to_google_sheet.py）
# GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/.../exec

# Service Account 方式（gspread 直接写入 Google Sheet，替代 webhook）
# GOOGLE_SHEET_ID=1omieOVachr1ig4j0egqnGvFxWR8ZzB5DgzGEgwouVww
# GOOGLE_SERVICE_ACCOUNT_FILE=./keys/google_service_account_key.json
# GOOGLE_SHEET_ROWS_SHEETNAME=video_enhancer_rows
# GOOGLE_SHEET_CARDS_SHEETNAME=video_enhancer_cards
